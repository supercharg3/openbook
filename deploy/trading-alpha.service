[Unit]
Description=Openbook alpha channel monitor (Telegram channel listener)
After=network.target
Restart=on-failure
RestartSec=30s

[Service]
Type=simple
User=trader
WorkingDirectory=/home/trader/ai-trading-system
EnvironmentFile=/home/trader/ai-trading-system/.env
ExecStart=/home/trader/ai-trading-system/.venv/bin/python -m src.run_alpha_monitor
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
