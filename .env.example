# Openbook config. Copy to .env and fill in YOUR OWN keys.
# Your setup agent will guide you, but it will NEVER ask you to paste keys to it —
# you paste each one here yourself. Keep this file private; .env is git-ignored.
#
# MINIMUM TO START (everything else is optional):
#   ANTHROPIC_API_KEY   — the brain (console.anthropic.com)
#   TELEGRAM_BOT_TOKEN  — your interface (@BotFather on Telegram)
# Add Binance for crypto trading, Alpaca for stock trading, Exa for news research.

# ── Claude (Anthropic) — the brain (required) ───────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001     # cheapest; fine to start

# ── Telegram — your interface (required) ────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=                          # your group id (negative); the bot reports it first run
TELEGRAM_TOPIC_ID=                         # optional: a forum-topic id to scope the bot to

# ── Alpaca — stocks (PAPER first; needed for the stock + swing sleeves) ──────
ALPACA_ENABLED=0
ALPACA_PAPER=1                             # 1 = practice money. Real money is a deliberate later step.
ALPACA_API_KEY_ID=                         # PAPER key id (starts with PK...)
ALPACA_API_SECRET=

# ── Binance — crypto (TRADE-ONLY key, withdrawals DISABLED) ─────────────────
# SAFETY: when creating your Binance API key, enable ONLY "Reading" + "Futures".
# Leave "Enable Withdrawals" OFF. Restrict the key to your server's IP address.
# A leaked key with these settings cannot drain your account.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Exa — news / research (optional; powers look-into + scan) ───────────────
EXA_API_KEY=
EXA_POLLS_PER_HOUR=2

# ── Sleeve selection (which engines to run) ──────────────────────────────────
# Comma-separated list. Remove any you don't want. All default to enabled.
#   pairs      — crypto market-neutral stat-arb (Binance). Needs BINANCE_API_KEY.
#   factor     — diversified stocks, benchmarked vs S&P 500 (Alpaca). Needs ALPACA keys.
#   factor-ai  — AI/chip stocks, benchmarked vs SMH (Alpaca). Needs ALPACA keys.
#   swing      — agentic conviction bets, stocks + crypto (Alpaca + Binance). Aggressive.
SLEEVES_ENABLED=pairs,factor,factor-ai,swing

# ── Capital budgets ──────────────────────────────────────────────────────────
# NOTE: these are PRACTICE amounts (simulated paper money) until you explicitly go live.
# You do NOT need real funds to start. Change these to match what you'd actually invest
# when you're ready to go live — the gate checker will prompt you when that time comes.
STARTING_CAPITAL_USD=500                   # crypto pairs sleeve budget
STOCK_SLEEVE_USD=10000                     # total for ALL enabled stock sleeves (split equally)
SWING_BUDGET_USD=1000                      # swing sleeve practice pot
SWING_FLOOR_PCT=0.20                       # halt swing if pot drops to this % of budget (20% = halt at $800 loss)

# ── Mode ─────────────────────────────────────────────────────────────────────
TRADING_MODE=dry-run                       # dry-run = paper. live requires an explicit, gated opt-in.
ALLOW_LIVE_ORDERS=0                        # safety lock — must be 1 to place real orders; set ONLY after gate clears
RESERVE_BUFFER_USD=100
CYCLE_SECONDS=60                           # trading loop interval; lower = more Binance API calls

# ── Web dashboard ────────────────────────────────────────────────────────────
DASHBOARD_PORT=8080
DASHBOARD_PUBLIC=0                         # 0 = private (localhost only). 1 = open to internet.
DASHBOARD_URL=                             # optional: override the URL sent to Telegram (e.g. if behind a proxy)

# ── Paths / schedule ────────────────────────────────────────────────────────
DB_PATH=./data/trading.db
TIMEZONE=Asia/Singapore
DAILY_REPORT_HOUR=8
